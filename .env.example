# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=production
PORT=5000
ENABLE_HTTP_LOGGING=true

# ── JWT ──────────────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRY=7d

# ── PostgreSQL ────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<db>
# In Docker Compose the host is the service name "db"
DATABASE_URL=postgresql://rooeel:rooeel_pass@db:5432/rooeel_db

# Postgres root credentials (used by the db container itself)
POSTGRES_USER=rooeel
POSTGRES_PASSWORD=rooeel_pass
POSTGRES_DB=rooeel_db

# ── Redis ─────────────────────────────────────
# In Docker Compose the host is the service name "redis"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_pass
# Default TTL for cached values (seconds)
REDIS_TTL=300

# ── Resend Email Configuration ────────────────
# Used for sending password reset emails
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_NAME=Rooeel
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Frontend URL ───────────────────────────────
# Used for password reset links in emails
FRONTEND_URL=http://localhost:3000
